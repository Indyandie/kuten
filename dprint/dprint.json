{
  "includes": [
    "**/*.{js,jsx,ts,tsx,json,md,mdx,css,scss,yaml,yml,html,svelte,astro,vto}"
  ],
  "excludes": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/target",
    "**/.git"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.95.15.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ],
  "typescript": {
    "semiColons": "asi",
    "quoteStyle": "alwaysSingle",
    "lineWidth": 999999,
    "indentWidth": 2,
    "useTabs": false
  },
  "json": {
    "lineWidth": 999999,
    "indentWidth": 2,
    "useTabs": false
  },
  "markdown": {
    "lineWidth": 999999,
    "textWrap": "always",
    "newLineKind": "lf",
    "emphasisKind": "underscores",
    "strongKind": "asterisks",
    "unorderedListKind": "dashes",
    "headingKind": "atx",
    "ignoreDirective": "formatter-ignore",
    "ignoreFileDirective": "formatter-ignore-file",
    "ignoreStartDirective": "formatter-ignore-start",
    "ignoreEndDirective": "formatter-ignore-end"
  },
  "pretty_yaml": {},
  "malva": {},
  "markup_fmt": {
    "print_width": 999999,
    "indent_width": 2
  }
}
